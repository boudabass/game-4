# ---- Odoo : connexion de base ----
# URL de l'instance Odoo (sans slash final)
ODOO_URL="https://www.theelsassisch.com"
# Nom de la base de données Odoo
ODOO_DB="theelsassisch"

# ---- Odoo : compte de service (écritures scores & sauvegardes) ----
# Identifiants d'UN utilisateur INTERNE dédié (pas un compte client/portail).
# L'app écrit scores et sauvegardes via ce compte ; les clients n'ont jamais
# d'accès direct aux modèles Odoo. Ne jamais commiter ces valeurs.
ODOO_API_LOGIN="arcade-bot@theelsassisch.com"
ODOO_API_PASSWORD="a_definir"

# ---- Cookies (optionnel) ----
# À définir uniquement quand l'app est servie sur un sous-domaine du site
# (ex. ".theelsassisch.com") pour partager la session en same-site.
# COOKIE_DOMAIN=".theelsassisch.com"
