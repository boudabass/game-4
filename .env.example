# ---- Odoo : authentification uniquement (login portail) ----
# URL de l'instance Odoo (sans slash final)
ODOO_URL="https://votre-instance.odoo.com"
# Nom de la base de données Odoo
ODOO_DB="votre_base"

# ---- PostgreSQL (catalogue, scores, sauvegardes) ----
# URL interne Coolify (la base n'est PAS exposée sur internet)
DATABASE_URL="postgres://utilisateur:mot_de_passe@hote-interne:5432/nom_base"

# ---- Session signée (HMAC) ----
# Chaîne aléatoire LONGUE (ex. `openssl rand -hex 32`). Ne jamais la publier.
SESSION_SECRET="chaine_aleatoire_longue"

# ---- Administration ----
# uid Odoo du compte autorisé à gérer le catalogue sur /admin
ADMIN_UID="1"

# ---- Cookies (optionnel) ----
# À définir uniquement quand l'app est servie sur un sous-domaine du site
# (ex. ".votre-domaine.com") pour partager la session en same-site.
# COOKIE_DOMAIN=".votre-domaine.com"
